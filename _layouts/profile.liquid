---
layout: default
---

<style>
  .member-profile-wrap {
    width: 90%;
    max-width: none;
    margin: 0 auto;
    padding: 2rem 0.35rem 4rem;
  }

  .member-profile-shell {
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.65);
    box-shadow: 0 24px 55px rgba(10, 28, 51, 0.2);
    overflow: hidden;
  }

  .member-profile-top {
    padding: 2.25rem;
    background: linear-gradient(140deg, rgba(236, 246, 255, 0.95) 0%, rgba(211, 236, 252, 0.85) 100%);
  }

  .member-photo {
    width: min(260px, 44vw);
    aspect-ratio: 1 / 1;
    border-radius: 20px;
    overflow: hidden;
    border: 4px solid #ffffff;
    box-shadow: 0 12px 30px rgba(8, 20, 48, 0.2);
    flex-shrink: 0;
    background: rgba(230, 240, 250, 0.9);
  }

  .member-photo figure,
  .member-photo picture,
  .member-photo .member-photo-img {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  .member-photo .member-photo-img {
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .member-meta-label {
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
    color: rgba(7, 34, 74, 0.6);
    margin-bottom: 0.35rem;
  }

  .member-meta-value {
    font-size: 1.06rem;
    line-height: 1.5;
    color: #12263f;
    font-weight: 600;
  }

  .member-chip {
    display: inline-flex;
    margin: 0 0.35rem 0.5rem 0;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(0, 93, 143, 0.25);
    background: rgba(0, 150, 199, 0.08);
    color: #0a3d62;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .member-links a {
    color: #0a3d62;
    font-weight: 700;
    text-decoration: none;
  }

  .member-links a:hover {
    text-decoration: underline;
  }

  .member-link-grid {
    display: grid;
    gap: 0.55rem;
  }

  .member-link-card {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    border-radius: 12px;
    border: 1px solid rgba(0, 93, 143, 0.25);
    background: rgba(0, 150, 199, 0.08);
    color: #0a3d62;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.92rem;
    padding: 0.5rem 0.75rem;
    transition: all 0.2s ease;
  }

  .member-link-card:hover {
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 8px 18px rgba(10, 61, 98, 0.15);
  }

  .member-bio {
    padding: 2rem 2.25rem 1rem;
  }

  @media (max-width: 767.98px) {
    .member-profile-top,
    .member-bio {
      padding: 1.25rem;
    }

    .member-photo {
      width: min(190px, 52vw);
    }
  }
</style>

{% assign raw_profile_img = page.image | default: 'assets/img/eddy_solomon.jpg' %}
{% if raw_profile_img contains '/' %}
  {% assign profile_img = raw_profile_img %}
{% else %}
  {% assign profile_img = raw_profile_img | prepend: 'assets/img/' %}
{% endif %}

{% assign person_key = page.person_key %}
{% if person_key == nil and page.permalink %}
  {% assign permalink_parts = page.permalink | split: '/' %}
  {% assign key_index = permalink_parts.size | minus: 2 %}
  {% assign person_key = permalink_parts[key_index] %}
{% endif %}
{% assign person_links = site.data.people_links[person_key] %}

{% if page.github_url %}
  {% assign github_url = page.github_url %}
{% elsif page.github_username %}
  {% assign github_url = 'https://github.com/' | append: page.github_username %}
{% endif %}
{% if person_links and person_links.github %}
  {% assign github_url = person_links.github %}
{% endif %}

{% if page.linkedin_url %}
  {% assign linkedin_url = page.linkedin_url %}
{% elsif page.linkedin_username %}
  {% assign linkedin_url = 'https://www.linkedin.com/in/' | append: page.linkedin_username %}
{% endif %}
{% if person_links and person_links.linkedin %}
  {% assign linkedin_url = person_links.linkedin %}
{% endif %}

{% assign email_address = page.email | default: site.email %}
{% if person_links and person_links.outlook %}
  {% assign email_address = person_links.outlook %}
{% endif %}
{% assign scholar_url = nil %}
{% if page.links %}
  {% for link in page.links %}
    {% assign link_label = link.label | downcase %}
    {% if link_label contains 'scholar' %}
      {% assign scholar_url = link.url %}
    {% endif %}
  {% endfor %}
{% endif %}
{% if person_links and person_links.scholar %}
  {% assign scholar_url = person_links.scholar %}
{% endif %}

<div class="member-profile-wrap">
  <section class="member-profile-shell">
    <div class="member-profile-top">
      <div class="row align-items-center">
        <div class="col-md-auto text-center mb-4 mb-md-0">
          <div class="member-photo mx-auto">
            {% capture member_sizes %}(min-width: 992px) 260px, (min-width: 768px) 44vw, 52vw{% endcapture %}
            {% include figure.liquid loading="eager" path=profile_img class="member-photo-img" sizes=member_sizes alt=page.title %}
          </div>
        </div>

        <div class="col-md">
          <h1 style="font-size: clamp(1.7rem, 2.4vw, 2.7rem); font-weight: 800; margin-bottom: 0.4rem; color: #09264d;">{{ page.title }}</h1>
          <p style="font-size: 1.1rem; margin-bottom: 1.3rem; color: #0a4d73; font-weight: 700;">{{ page.description }}</p>

          <div class="row">
            <div class="col-lg-6 mb-3 mb-lg-0">
              <div class="member-meta-label">Role in Lab</div>
              <div class="member-meta-value">{{ page.role_in_lab | default: page.description }}</div>
            </div>
            <div class="col-lg-6">
              <div class="member-meta-label">Research Field</div>
              {% if page.research_fields %}
                <div>
                  {% for field in page.research_fields %}
                    <span class="member-chip">{{ field }}</span>
                  {% endfor %}
                </div>
              {% else %}
                <div class="member-meta-value">MRI, medical imaging, and computational methods</div>
              {% endif %}
            </div>
          </div>

          <div class="row mt-3">
            <div class="col-lg-6 mb-3 mb-lg-0">
              <div class="member-meta-label">Contact Email</div>
              <div class="member-links"><a href="mailto:{{ email_address }}">{{ email_address }}</a></div>
            </div>
            <div class="col-lg-6">
              <div class="member-meta-label">Useful Links</div>
              <div class="member-link-grid">
                {% if github_url %}
                  <a href="{{ github_url }}" target="_blank" rel="noopener" class="member-link-card">GitHub</a>
                {% endif %}
                {% if linkedin_url %}
                  <a href="{{ linkedin_url }}" target="_blank" rel="noopener" class="member-link-card">LinkedIn</a>
                {% endif %}
                {% if person_key == 'eddy-solomon' and scholar_url %}
                  <a href="{{ scholar_url }}" target="_blank" rel="noopener" class="member-link-card">Google Scholar</a>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="member-bio">
      <h2 style="font-size: 1.25rem; font-weight: 800; color: #0b2f59; margin-bottom: 0.9rem;">Short Bio</h2>
      <div style="font-size: 1.05rem; line-height: 1.75; color: #142f4d;">
        {{ content }}
      </div>
    </div>
  </section>
</div>
