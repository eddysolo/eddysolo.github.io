---
layout: default
---

<div class="profile-container position-relative" style="min-height: 100vh; overflow: hidden; padding-bottom: 5rem;">
  <!-- Background Image spanning the entire page -->
  <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: -2; background-image: url('{{ "assets/img/ChatGPT_brain_scan_idea.png" | relative_url }}'); background-size: cover; background-position: center; filter: blur(8px) brightness(0.3);"></div>
  <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; background: linear-gradient(180deg, rgba(8, 20, 48, 0.8) 0%, rgba(0, 93, 143, 0.6) 100%); mix-blend-mode: multiply;"></div>

  <div class="container-fluid px-0 mx-auto mt-5" style="max-width: 95%; width: calc(100% - 2rem); z-index: 1;">
    
    <!-- Profile Card -->
    <div class="glass-section w-100 d-flex flex-column align-items-center mb-5 text-center" style="border-radius: 24px; padding: 4rem 3rem; background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(20px);">
      {% capture profile_img %}{% if page.image %}{{ page.image }}{% else %}assets/img/prof_pic.jpg{% endif %}{% endcapture %}
      
      <div style="width: 200px; height: 200px; border-radius: 50%; overflow: hidden; border: 4px solid var(--global-theme-color); margin-bottom: 2rem; box-shadow: 0 10px 30px rgba(0,0,0,0.2);">
        <img src="{{ profile_img | relative_url }}" alt="{{ page.title }}" style="width: 100%; height: 100%; object-fit: cover;">
      </div>
      
      <h1 style="font-weight: 800; font-size: 3.5rem; letter-spacing: -0.02em; margin-bottom: 0.5rem; color: var(--global-text-color);">{{ page.title }}</h1>
      <h3 style="font-weight: 600; font-size: 1.5rem; color: var(--global-theme-color); margin-bottom: 2rem;">{{ page.description }}</h3>
      
      <div class="profile-content text-left" style="font-size: 1.25rem; line-height: 1.8; color: var(--global-text-color); max-width: 800px; width: 100%;">
        {{ content }}
      </div>
    </div>

    <!-- Join Us Box -->
    <div class="glass-box text-center p-5" style="border-radius: 24px; background: rgba(0, 150, 199, 0.15); border: 1px solid rgba(255,255,255,0.2);">
      <h2 style="font-weight: 800; font-size: 2.5rem; color: white; margin-bottom: 1rem; text-shadow: 0 2px 10px rgba(0,0,0,0.5);">Want to Work with {{ page.title | split: ' ' | first }}?</h2>
      <p style="font-size: 1.25rem; color: #f0f8ff; margin-bottom: 2.5rem; text-shadow: 0 1px 5px rgba(0,0,0,0.5);">
        Solomon's MRI Lab is always looking for brilliant post-docs and students. Join our team and push the boundaries of medical imaging.
      </p>
      <a href="{{ '/contact/' | relative_url }}" class="btn btn-light btn-lg text-uppercase" style="font-weight: 700; padding: 1rem 3rem; border-radius: 12px; color: #111424; box-shadow: 0 10px 25px rgba(255,255,255,0.2);">Join Us</a>
    </div>
    
  </div>
</div>
