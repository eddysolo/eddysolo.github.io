---
layout: page
---
<div class="post">
  <article>
    {% if page.profiles %}
      <div class="row row-cols-1 row-cols-md-3 g-4">
        {% for profile in page.profiles %}
          <div class="col">
            <a href="{{ profile.url | relative_url }}" class="text-decoration-none">
              <div class="card h-100 border-0">
                {% if profile.image %}
                  {% assign profile_image_path = profile.image | prepend: 'assets/img/' %}
                  {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px) 30vw, 95vw"{% endcapture %}
                  {% include figure.liquid loading="eager" path=profile_image_path class="card-img-top" sizes=sizes alt=profile.name %}
                {% endif %}
                <div class="card-body bg-white text-center pb-4 pt-3">
                  <h4 class="card-title fw-bold mb-1 text-dark">{{ profile.name }}</h4>
                  <p class="card-text text-muted mb-0" style="font-size: 0.95rem;">{{ profile.role }}</p>
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </article>
</div>
