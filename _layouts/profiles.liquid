---
layout: page
---
<style>
  .profile-card .card-img-top {
    aspect-ratio: 1 / 1;
    width: 100%;
    object-fit: cover;
    object-position: var(--profile-image-position, center);
    display: block;
    transition: filter 0.3s ease;
  }

  .profile-card:hover .card-img-top {
    filter: grayscale(100%);
  }

  .alumni-simple-list {
    max-width: 560px;
    margin: 0 auto 3rem;
    padding: 0;
    list-style: none;
  }

  .alumni-simple-item {
    padding: 0.65rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    color: var(--global-text-color);
  }

  .alumni-simple-item:last-child {
    border-bottom: 0;
  }

  .alumni-simple-link {
    color: inherit;
    text-decoration: none;
  }

  .alumni-simple-link:hover {
    color: var(--global-theme-color);
    text-decoration: none;
  }
</style>
<div class="post">
  <article>
    {% assign profile_links_enabled = true %}
    {% if page.enable_profile_links == false %}
      {% assign profile_links_enabled = false %}
    {% endif %}

    {% if page.profiles %}
      <div class="row row-cols-1 row-cols-md-3 g-4 profile-grid">
        {% for profile in page.profiles %}
          <div class="col profile-grid-item">
            {% if profile_links_enabled and profile.url %}
              <a href="{{ profile.url | relative_url }}" class="text-decoration-none">
            {% endif %}
            <div
              class="card h-100 border-0 text-center profile-card"
              style="--profile-image-position: {{ profile.image_position | default: 'center' }};"
            >
              {% if profile.image %}
                {% assign profile_image_path = profile.image | prepend: 'assets/img/' %}
                {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px) 30vw, 95vw{% endcapture %}
                {% include figure.liquid loading="eager" path=profile_image_path class="card-img-top" sizes=sizes alt=profile.name %}
              {% endif %}
              <div class="card-body pb-4 pt-3">
                <h4 class="card-title fw-bold mb-1" style="font-size: calc(1.5rem - 2px); color: var(--global-text-color);">{{ profile.name }}</h4>
                <p class="card-text text-muted mb-0" style="font-size: 0.92rem;">{{ profile.role }}</p>
              </div>
            </div>
            {% if profile_links_enabled and profile.url %}
              </a>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if page.alumni_profiles %}
      <h2 class="text-center mt-5 mb-3" style="font-weight: 800; letter-spacing: 0.03em; color: var(--global-text-color);">Alumni</h2>
      <ul class="alumni-simple-list">
        {% for profile in page.alumni_profiles %}
          <li class="alumni-simple-item">
            {% if profile_links_enabled and profile.url %}
              <a href="{{ profile.url | relative_url }}" class="alumni-simple-link">
                <strong>{{ profile.name }}</strong>{% if profile.role %} <span class="text-muted">- {{ profile.role }}</span>{% endif %}
              </a>
            {% else %}
              <strong>{{ profile.name }}</strong>{% if profile.role %} <span class="text-muted">- {{ profile.role }}</span>{% endif %}
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </article>
</div>
