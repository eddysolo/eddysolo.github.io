document.addEventListener("DOMContentLoaded",function(){const e=document.querySelectorAll(".card, .section-heading, .publication-entry, .post-header h1, .hero-banner, article > p:first-of-type, .profile-grid-item"),t=new IntersectionObserver(e=>{e.forEach(e=>{e.isIntersecting&&(e.target.classList.add("fade-in-visible"),t.unobserve(e.target))})},{threshold:.12});e.forEach(e=>{e.classList.add("fade-in-hidden"),t.observe(e)})});