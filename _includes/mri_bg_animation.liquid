<!-- MRI Lab Background Animation Canvas -->
<canvas id="mri-bg-animation" style="position: absolute; top: 0; left: 0; width: 100vw; height: 100%; z-index: 1; pointer-events: none; opacity: 0.8;"></canvas>

<script>
document.addEventListener("DOMContentLoaded", function() {
    const canvas = document.getElementById('mri-bg-animation');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    
    let width, height;
    function resize() {
        const container = canvas.parentElement; // should be global-hero-carousel
        width = container.offsetWidth;
        height = container.offsetHeight;
        canvas.width = width;
        canvas.height = height;
    }
    
    // resize observer on the parent container
    const resizeObserver = new ResizeObserver(() => resize());
    if (canvas.parentElement) {
        resizeObserver.observe(canvas.parentElement);
        resize();
    } else {
        window.addEventListener('resize', resize);
        width = window.innerWidth;
        height = canvas.offsetHeight || 500;
        canvas.width = width;
        canvas.height = height;
    }

    // Nodes logic
    const nodes = [];
    const numNodes = 70;
    
    class Node {
        constructor() {
            this.x = Math.random() * width;
            this.y = Math.random() * height;
            this.vx = (Math.random() - 0.5) * 1.5;
            this.vy = (Math.random() - 0.5) * 1.5;
            this.radius = Math.random() * 2 + 1;
            // giving the nodes a nice energetic cyan/blue flavor
            this.color = `rgba(0, ${Math.floor(Math.random()*150 + 100)}, 255, ${Math.random()*0.5 + 0.3})`;
            this.pulseCounter = Math.random() * Math.PI * 2;
            this.pulseSpeed = 0.02 + Math.random() * 0.04;
        }

        update() {
            this.x += this.vx;
            this.y += this.vy;
            
            // bounce
            if(this.x <= 0 || this.x >= width) this.vx *= -1;
            if(this.y <= 0 || this.y >= height) this.vy *= -1;
            
            this.pulseCounter += this.pulseSpeed;
        }

        draw() {
            const currentRadius = this.radius + Math.sin(this.pulseCounter) * 1.5;
            
            ctx.beginPath();
            ctx.arc(this.x, this.y, currentRadius > 0 ? currentRadius : 0.1, 0, Math.PI * 2);
            ctx.fillStyle = this.color;
            ctx.fill();
        }
    }

    // populate
    for(let i=0; i<numNodes; i++) {
        nodes.push(new Node());
    }

    function drawFieldLines() {
        for(let i=0; i<numNodes; i++) {
            for(let j=i+1; j<numNodes; j++) {
                const dx = nodes[i].x - nodes[j].x;
                const dy = nodes[i].y - nodes[j].y;
                const dist = Math.sqrt(dx*dx + dy*dy);
                
                if(dist < 150) {
                    ctx.beginPath();
                    // magnetic blue gradient fields effect
                    ctx.strokeStyle = `rgba(0, 200, 255, ${1 - dist/150})`;
                    ctx.lineWidth = 0.5;
                    ctx.moveTo(nodes[i].x, nodes[i].y);
                    
                    // Bezier curve to simulate magnetic flux line
                    const cvx = (nodes[i].x + nodes[j].x) / 2 + (Math.sin(Date.now() * 0.001) * 20);
                    const cvy = (nodes[i].y + nodes[j].y) / 2 + (Math.cos(Date.now() * 0.001) * 20);
                    
                    ctx.quadraticCurveTo(cvx, cvy, nodes[j].x, nodes[j].y);
                    ctx.stroke();
                }
            }
        }
    }

    function animate() {
        ctx.clearRect(0, 0, width, height);
        
        // draw magnetic field lines between nodes
        drawFieldLines();
        
        nodes.forEach(node => {
            node.update();
            node.draw();
        });
        
        requestAnimationFrame(animate);
    }
    
    animate();
});
</script>
